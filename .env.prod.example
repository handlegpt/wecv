# 数据库配置
DB_PASSWORD=your_secure_db_password
DATABASE_URL=postgresql://postgres:your_secure_db_password@db:5432/wecv_ai

# JWT 配置
JWT_SECRET=your_very_secure_jwt_secret_key_wecv_ai_2024

# OpenAI 配置
OPENAI_API_KEY=your_openai_api_key_here

# Redis 配置
REDIS_URL=redis://redis:6379

# 应用配置
NODE_ENV=production
PORT=3001

# 前端配置
NEXT_PUBLIC_API_URL=https://api.wecv.ai
NEXT_PUBLIC_APP_NAME=WeCV AI

# 域名配置
DOMAIN=wecv.ai

# 邮件配置（用于邮件验证登录）
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password
FRONTEND_URL=https://wecv.ai 